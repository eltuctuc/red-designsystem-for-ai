{
  "$schema": "../../schemas/contract.schema.json",
  "id": "progress",
  "title": "Progress",
  "description": "Progress indicator for operations (determinate/indeterminate). Use when tasks take noticeable time.",
  "anatomy": {
    "parts": ["root", "track", "bar", "label", "value-text"],
    "slots": []
  },
  "props": [
    {
      "name": "mode",
      "type": "string",
      "required": false,
      "default": "indeterminate",
      "enum": ["indeterminate", "determinate"],
      "description": "Determinate shows percentage; indeterminate shows ongoing activity."
    },
    {
      "name": "value",
      "type": "number",
      "required": false,
      "description": "0–100 for determinate mode."
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "description": "Accessible label (e.g. \"Uploading\")."
    }
  ],
  "states": [
    {
      "name": "indeterminate",
      "description": "Unknown progress.",
      "effects": ["Animated bar; respect reduced motion."]
    },
    {
      "name": "determinate",
      "description": "Known progress.",
      "effects": ["Bar length reflects value; optionally show percentage text."]
    }
  ],
  "events": [],
  "a11y": {
    "keyboard": [
      "Progress is not interactive."
    ],
    "aria": [
      "Use role=\"progressbar\" with aria-valuemin/max and aria-valuenow for determinate mode.",
      "For indeterminate, omit aria-valuenow and rely on aria-label/aria-labelledby."
    ]
  },
  "invariants": {
    "must": [
      "Determinate progress must expose value to assistive tech.",
      "Respect prefers-reduced-motion in indeterminate animations."
    ],
    "should": [
      "For long tasks, include descriptive text about what is happening."
    ],
    "must_not": [
      "Do not fake determinate values if you do not have real progress."
    ]
  },
  "token_usage": [
    {
      "token": "semantic.color.bg.muted",
      "maps_to": "Track background",
      "notes": "Muted background for track."
    },
    {
      "token": "semantic.color.bg.accent",
      "maps_to": "Bar fill",
      "notes": "Use accent for progress fill."
    },
    {
      "token": "semantic.radius.control",
      "maps_to": "Shape",
      "notes": "Use control radius for track/bar."
    }
  ],
  "examples": [
    {
      "title": "ARIA progressbar (determinate)",
      "html": "<div role=\"progressbar\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-valuenow=\"60\" aria-label=\"Uploading\"></div>"
    }
  ]
}

