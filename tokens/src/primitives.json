{
  "$schema": "../../schemas/tokens.schema.json",
  "primitives": {
    "color": {
      "neutral": {
        "0": { "$type": "color", "$value": "#ffffff" },
        "50": { "$type": "color", "$value": "#f7f7f8" },
        "100": { "$type": "color", "$value": "#efeff2" },
        "200": { "$type": "color", "$value": "#dadbe0" },
        "300": { "$type": "color", "$value": "#c0c2cc" },
        "400": { "$type": "color", "$value": "#a2a6b5" },
        "500": { "$type": "color", "$value": "#7f8498" },
        "600": { "$type": "color", "$value": "#5d6274" },
        "700": { "$type": "color", "$value": "#3f4352" },
        "800": { "$type": "color", "$value": "#2b2e39" },
        "900": { "$type": "color", "$value": "#1c1e25" },
        "1000": { "$type": "color", "$value": "#0f1014" }
      },
      "blue": {
        "50": { "$type": "color", "$value": "#eff6ff" },
        "100": { "$type": "color", "$value": "#dbeafe" },
        "200": { "$type": "color", "$value": "#bfdbfe" },
        "300": { "$type": "color", "$value": "#93c5fd" },
        "400": { "$type": "color", "$value": "#60a5fa" },
        "500": { "$type": "color", "$value": "#3b82f6" },
        "600": { "$type": "color", "$value": "#2563eb" },
        "700": { "$type": "color", "$value": "#1d4ed8" }
      },
      "amber": {
        "500": { "$type": "color", "$value": "#f59e0b" },
        "600": { "$type": "color", "$value": "#d97706" }
      },
      "purple": {
        "500": { "$type": "color", "$value": "#a855f7" },
        "600": { "$type": "color", "$value": "#9333ea" }
      },
      "red": {
        "500": { "$type": "color", "$value": "#ef4444" },
        "600": { "$type": "color", "$value": "#dc2626" }
      },
      "green": {
        "500": { "$type": "color", "$value": "#22c55e" },
        "600": { "$type": "color", "$value": "#16a34a" }
      }
    },
    "radius": {
      "sm": { "$type": "dimension", "$value": "6px" },
      "md": { "$type": "dimension", "$value": "10px" },
      "lg": { "$type": "dimension", "$value": "14px" },
      "pill": { "$type": "dimension", "$value": "999px" }
    },
    "space": {
      "0": { "$type": "dimension", "$value": "0px" },
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "5": { "$type": "dimension", "$value": "20px" },
      "6": { "$type": "dimension", "$value": "24px" },
      "8": { "$type": "dimension", "$value": "32px" },
      "10": { "$type": "dimension", "$value": "40px" },
      "12": { "$type": "dimension", "$value": "48px" }
    },
    "font": {
      "family": {
        "sans": {
          "$type": "fontFamily",
          "$value": "ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, \"Apple Color Emoji\", \"Segoe UI Emoji\""
        }
      },
      "size": {
        "sm": { "$type": "fontSize", "$value": "14px" },
        "md": { "$type": "fontSize", "$value": "16px" },
        "lg": { "$type": "fontSize", "$value": "18px" },
        "xl": { "$type": "fontSize", "$value": "22px" }
      },
      "weight": {
        "regular": { "$type": "fontWeight", "$value": 400 },
        "medium": { "$type": "fontWeight", "$value": 500 },
        "semibold": { "$type": "fontWeight", "$value": 600 }
      },
      "lineHeight": {
        "tight": { "$type": "lineHeight", "$value": 1.2 },
        "normal": { "$type": "lineHeight", "$value": 1.5 }
      }
    },
    "shadow": {
      "sm": { "$type": "shadow", "$value": "0 1px 2px rgba(15,16,20,0.08)" },
      "md": { "$type": "shadow", "$value": "0 8px 24px rgba(15,16,20,0.12)" }
    },
    "motion": {
      "duration": {
        "fast": { "$type": "duration", "$value": "120ms" },
        "normal": { "$type": "duration", "$value": "180ms" }
      },
      "easing": {
        "standard": { "$type": "cubicBezier", "$value": "cubic-bezier(0.2, 0, 0, 1)" }
      }
    }
  }
}
